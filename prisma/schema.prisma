generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  AGENT
  BACKOFFICE
  ADMIN
  FINANCE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClientRecordStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum BonusPoolStatus {
  PENDING
  DISTRIBUTED
}

enum AllocationStatus {
  PENDING
  PAID
}

enum AllocationType {
  DIRECT
  STAR_SLICE
  BACKFILL
}

enum LeadershipTier {
  NONE
  ED
  SED
  MD
  CMO
}

enum QuarterlySettlementStatus {
  DRAFT
  APPROVED
  PAID
}

enum PhoneAssignmentStatus {
  SIGNED_OUT
  RETURNED
}

enum TodoStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum EventType {
  LOGIN
  LOGOUT
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  CLIENT_APPROVED
  BONUS_POOL_CREATED
  BONUS_POOL_DISTRIBUTED
  STAR_LEVEL_CHANGED
  LEADERSHIP_PROMOTED
  ALLOCATION_PAID
  QUARTERLY_SETTLEMENT_CREATED
  CLIENT_DRAFT_CREATED
  CLIENT_DRAFT_SUBMITTED
  DEVICE_SIGNED_OUT
  DEVICE_RETURNED
  DEVICE_REISSUED
  TODO_ASSIGNED
  TODO_COMPLETED
  TODO_REVERTED
  CLIENT_APPROVED_NOTIFICATION
  CLIENT_APPROVAL_REVERTED
  FUND_ALLOCATED
  DEBIT_CARD_UPLOADED
  GMAIL_SYNCED
  EMAIL_TODO_CREATED
  FUND_CONFIRMED
  FUND_DISCREPANCY_FLAGGED
}

// --- User -------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  role         UserRole @default(AGENT)
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Hierarchy
  supervisorId String?
  supervisor   User?  @relation("UserHierarchy", fields: [supervisorId], references: [id])
  subordinates User[] @relation("UserHierarchy")

  // Agent profile
  tier          String @default("rookie")
  starLevel     Int    @default(0)
  leadershipTier LeadershipTier @default(NONE)
  gender        String?
  dateOfBirth   DateTime?
  idNumber      String?
  idExpiry      DateTime?
  idDocument      String?
  addressDocument String?
  ssn             String?
  citizenship   String?
  personalEmail String?
  personalPhone String?
  companyPhone  String?
  carrier       String?
  zelle         String?
  address       String?
  loginAccount  String?

  // Relations
  eventLogs              EventLog[]
  reviewedApplications   AgentApplication[] @relation("ApplicationReviewer")
  resultOfApplications   AgentApplication[] @relation("ApplicationResult")
  clientRecords          ClientRecord[]     @relation("RecordCloser")
  closedBonusPools       BonusPool[]        @relation("BonusPoolCloser")
  allocations            BonusAllocation[]  @relation("AllocationAgent")
  allocationsPaidBy      BonusAllocation[]  @relation("AllocationPayer")
  promotionLogs          PromotionLog[]
  quarterlySettlements   QuarterlySettlement[]
  phoneAssignmentsAsAgent  PhoneAssignment[] @relation("PhoneAgent")
  phoneAssignmentsAsIssuer PhoneAssignment[] @relation("PhoneSignedOutBy")
  assignedTodos            Todo[]            @relation("TodoAssignedTo")
  createdTodos             Todo[]            @relation("TodoCreatedBy")
  fundAllocations          FundAllocation[]  @relation("FundRecordedBy")
  fundConfirmations        FundAllocation[]  @relation("FundConfirmedBy")
}

// --- Agent Application ------------------------------------------

model AgentApplication {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)

  // Applicant info
  firstName   String
  lastName    String
  email       String
  phone       String
  password    String // hashed

  // Personal
  gender      String?
  dateOfBirth DateTime?
  citizenship String?

  // Address
  address String?
  city    String?
  state   String?
  zipCode String?
  country String?

  // ID document
  idDocument      String?
  addressDocument String?
  idNumber        String?
  idExpiry        DateTime?

  // Payment
  zelle String?

  // Referral
  referredByName String?

  // Review
  reviewedById String?
  reviewedBy   User?    @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?

  // Links to created user on approval
  resultUserId String?
  resultUser   User?   @relation("ApplicationResult", fields: [resultUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Client Record (unified: draft through approved lifecycle) ---

model ClientRecord {
  id     String             @id @default(cuid())
  status ClientRecordStatus @default(DRAFT)
  step   Int                @default(1)

  // Step 1: Pre-Qual
  firstName             String?
  lastName              String?
  email                 String?
  phone                 String?
  idDocument            String?
  idNumber              String?
  idExpiry              DateTime?
  dateOfBirth           DateTime?
  address               String?
  assignedGmail         String?
  gmailPassword         String?
  gmailScreenshot       String?
  betmgmCheckPassed     Boolean?
  betmgmLogin           String?
  betmgmPassword        String?
  betmgmRegScreenshot   String?
  betmgmLoginScreenshot String?

  livesAtDifferentAddress  Boolean  @default(false)
  currentAddress           String?
  differentAddressDuration String?
  differentAddressProof    String?

  // Step 2: Background
  ssnDocument        String?
  ssnNumber          String?
  citizenship        String?
  missingIdType      String?
  secondAddress      String?
  secondAddressProof String?
  hasCriminalRecord  Boolean?
  criminalRecordNotes String?
  bankingHistory     String?
  bankNegativeBalance Boolean?
  paypalHistory         String?
  paypalSsnLinked       Boolean  @default(false)
  paypalBrowserVerified Boolean  @default(false)
  occupation            String?
  annualIncome          String?
  employmentStatus      String?
  maritalStatus         String?
  creditScoreRange      String?
  dependents            String?
  educationLevel        String?
  householdAwareness    String?
  familyTechSupport     String?
  financialAutonomy     String?
  digitalComfort        String?
  deviceReservationDate String?
  sportsbookHistory     String?
  sportsbookUsedBefore  Boolean  @default(false)
  sportsbookUsedList    String?
  sportsbookStatuses    String?

  // Step 3: Platforms
  platformData           Json?
  generatedCredentials   Json?

  // Step 4: Contract
  contractDocument String?

  // Step 4: Agent Assessment
  agentConfidenceLevel  String?    // "high" | "medium" | "low"
  clientHidingInfo      Boolean    @default(false)
  clientHidingInfoNotes String?

  // Address discovery (progressive OCR across screenshots)
  discoveredAddresses Json?

  // Risk flags
  paypalPreviouslyUsed Boolean @default(false)
  addressMismatch      Boolean @default(false)
  debankedHistory      Boolean @default(false)
  debankedBank         String?
  undisclosedInfo      Boolean @default(false)

  // Backoffice review tracking
  backofficeReviewedStep Int @default(0)

  // Approval
  approvedAt DateTime?

  // Relations
  closerId         String
  closer           User    @relation("RecordCloser", fields: [closerId], references: [id])
  bonusPool        BonusPool?
  phoneAssignments PhoneAssignment[]
  todos            Todo[]
  transactions     Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Bonus Pool -------------------------------------------------

model BonusPool {
  id             String          @id @default(cuid())
  clientRecordId String          @unique
  clientRecord   ClientRecord    @relation(fields: [clientRecordId], references: [id])

  closerId       String
  closer         User   @relation("BonusPoolCloser", fields: [closerId], references: [id])
  closerStarLevel Int

  totalAmount    Int @default(400)
  directAmount   Int @default(200)
  starPoolAmount Int @default(200)

  distributedSlices Int @default(0)
  recycledSlices    Int @default(0)

  status        BonusPoolStatus @default(PENDING)
  distributedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocations BonusAllocation[]
}

// --- Bonus Allocation -------------------------------------------

model BonusAllocation {
  id     String         @id @default(cuid())
  poolId String
  pool   BonusPool      @relation(fields: [poolId], references: [id])

  agentId       String
  agent         User           @relation("AllocationAgent", fields: [agentId], references: [id])
  agentStarLevel Int

  type    AllocationType
  slices  Int
  amount  Int

  status  AllocationStatus @default(PENDING)
  paidAt  DateTime?
  paidById String?
  paidBy   User?   @relation("AllocationPayer", fields: [paidById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Promotion Log ----------------------------------------------

model PromotionLog {
  id      String @id @default(cuid())
  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  previousStarLevel    Int
  newStarLevel         Int
  previousLeadershipTier LeadershipTier @default(NONE)
  newLeadershipTier      LeadershipTier @default(NONE)
  promotionBonus       Int?
  approvedClientCount  Int
  metadata             Json?

  createdAt DateTime @default(now())
}

// --- Quarterly Settlement ---------------------------------------

model QuarterlySettlement {
  id       String @id @default(cuid())
  leaderId String
  leader   User   @relation(fields: [leaderId], references: [id])

  leaderTier        LeadershipTier
  year              Int
  quarter           Int
  teamRevenue       Decimal @db.Decimal(12, 2)
  commissionPercent Int
  commissionAmount  Decimal @db.Decimal(12, 2)
  teamAgentIds      String[]
  metadata          Json?

  status QuarterlySettlementStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leaderId, year, quarter])
}

// --- Phone Assignment -------------------------------------------

model PhoneAssignment {
  id          String  @id @default(cuid())
  phoneNumber String
  carrier     String?
  deviceId    String?
  notes       String?

  clientRecordId String
  clientRecord   ClientRecord @relation(fields: [clientRecordId], references: [id])

  agentId String
  agent   User   @relation("PhoneAgent", fields: [agentId], references: [id])

  signedOutById String
  signedOutBy   User   @relation("PhoneSignedOutBy", fields: [signedOutById], references: [id])

  signedOutAt DateTime              @default(now())
  dueBackAt   DateTime
  returnedAt  DateTime?

  status PhoneAssignmentStatus @default(SIGNED_OUT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Todo -------------------------------------------------------

model Todo {
  id            String     @id @default(cuid())
  title         String
  description   String?
  issueCategory String

  clientRecordId String?
  clientRecord   ClientRecord? @relation(fields: [clientRecordId], references: [id])

  assignedToId  String
  assignedTo    User   @relation("TodoAssignedTo", fields: [assignedToId], references: [id])

  createdById   String
  createdBy     User   @relation("TodoCreatedBy", fields: [createdById], references: [id])

  dueDate       DateTime
  completedAt   DateTime?
  status        TodoStatus @default(PENDING)
  metadata      Json?
  source        String     @default("MANUAL")
  processedEmailId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- Fund Allocation --------------------------------------------

model FundAllocation {
  id         String   @id @default(cuid())
  amount     Decimal  @db.Decimal(12, 2)
  platform   String
  direction  String
  notes      String?

  recordedById String
  recordedBy   User   @relation("FundRecordedBy", fields: [recordedById], references: [id])

  confirmationStatus  String   @default("UNCONFIRMED")
  confirmedAt         DateTime?
  confirmedById       String?
  confirmedBy         User?    @relation("FundConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAmount     Decimal? @db.Decimal(12, 2)
  emailConfirmationId String?
  discrepancyNotes    String?

  createdAt  DateTime @default(now())
}

// --- Gmail Integration ------------------------------------------

model GmailIntegration {
  id           String    @id @default(cuid())
  inboxEmail   String    @unique
  refreshToken String
  accessToken  String?
  tokenExpiry  DateTime?
  historyId    String?
  lastSyncAt   DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// --- Processed Email --------------------------------------------

model ProcessedEmail {
  id             String   @id @default(cuid())
  gmailMessageId String   @unique
  threadId       String?
  from           String
  subject        String
  snippet        String?
  receivedAt     DateTime
  detectionType  String
  detectionData  Json?
  processed      Boolean  @default(false)
  todoId         String?
  fundAllocationId String?
  createdAt      DateTime @default(now())
}

// --- Transaction ------------------------------------------------

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

model Transaction {
  id             String          @id @default(cuid())
  clientRecordId String
  clientRecord   ClientRecord    @relation(fields: [clientRecordId], references: [id])

  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  description  String?
  platformType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Event Log --------------------------------------------------

model EventLog {
  id          String    @id @default(cuid())
  eventType   EventType
  description String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  metadata    Json?
  createdAt   DateTime  @default(now())
}
