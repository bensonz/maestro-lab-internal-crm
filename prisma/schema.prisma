generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  AGENT
  BACKOFFICE
  ADMIN
  FINANCE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClientStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CLOSED
}

enum BonusPoolStatus {
  PENDING
  DISTRIBUTED
}

enum AllocationStatus {
  PENDING
  PAID
}

enum AllocationType {
  DIRECT
  STAR_SLICE
  BACKFILL
}

enum LeadershipTier {
  NONE
  ED
  SED
  MD
  CMO
}

enum QuarterlySettlementStatus {
  DRAFT
  APPROVED
  PAID
}

enum ClientDraftStatus {
  DRAFT
  SUBMITTED
}

enum EventType {
  LOGIN
  LOGOUT
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  CLIENT_APPROVED
  BONUS_POOL_CREATED
  BONUS_POOL_DISTRIBUTED
  STAR_LEVEL_CHANGED
  LEADERSHIP_PROMOTED
  ALLOCATION_PAID
  QUARTERLY_SETTLEMENT_CREATED
  CLIENT_DRAFT_CREATED
  CLIENT_DRAFT_SUBMITTED
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  role         UserRole @default(AGENT)
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Hierarchy
  supervisorId String?
  supervisor   User?  @relation("UserHierarchy", fields: [supervisorId], references: [id])
  subordinates User[] @relation("UserHierarchy")

  // Agent profile
  tier          String @default("rookie")
  starLevel     Int    @default(0)
  leadershipTier LeadershipTier @default(NONE)
  gender        String?
  dateOfBirth   DateTime?
  idNumber      String?
  idExpiry      DateTime?
  idDocument      String?
  addressDocument String?
  ssn             String?
  citizenship   String?
  personalEmail String?
  personalPhone String?
  companyPhone  String?
  carrier       String?
  zelle         String?
  address       String?
  loginAccount  String?

  // Relations
  eventLogs              EventLog[]
  reviewedApplications   AgentApplication[] @relation("ApplicationReviewer")
  resultOfApplications   AgentApplication[] @relation("ApplicationResult")
  closedClients          Client[]           @relation("ClientCloser")
  closedBonusPools       BonusPool[]        @relation("BonusPoolCloser")
  allocations            BonusAllocation[]  @relation("AllocationAgent")
  allocationsPaidBy      BonusAllocation[]  @relation("AllocationPayer")
  promotionLogs          PromotionLog[]
  quarterlySettlements   QuarterlySettlement[]
  clientDrafts           ClientDraft[]      @relation("DraftCloser")
}

// ─── Agent Application ───────────────────────────────────

model AgentApplication {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)

  // Applicant info
  firstName   String
  lastName    String
  email       String
  phone       String
  password    String // hashed

  // Personal
  gender      String?
  dateOfBirth DateTime?
  citizenship String?

  // Address
  address String?
  city    String?
  state   String?
  zipCode String?
  country String?

  // ID document
  idDocument      String?
  addressDocument String?
  idNumber        String?
  idExpiry        DateTime?

  // Payment
  zelle String?

  // Referral
  referredByName String?

  // Review
  reviewedById String?
  reviewedBy   User?    @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?

  // Links to created user on approval
  resultUserId String?
  resultUser   User?   @relation("ApplicationResult", fields: [resultUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Client (minimal) ───────────────────────────────────

model Client {
  id        String       @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  status    ClientStatus @default(PENDING)

  closerId  String
  closer    User     @relation("ClientCloser", fields: [closerId], references: [id])

  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  bonusPool BonusPool?
  fromDraft ClientDraft? @relation("DraftResult")
}

// ─── Client Draft ──────────────────────────────────────

model ClientDraft {
  id     String            @id @default(cuid())
  status ClientDraftStatus @default(DRAFT)
  step   Int               @default(1)

  // Step 1: Pre-Qual
  firstName             String?
  lastName              String?
  email                 String?
  phone                 String?
  idDocument            String?
  idNumber              String?
  idExpiry              DateTime?
  dateOfBirth           DateTime?
  address               String?
  assignedGmail         String?
  gmailPassword         String?
  gmailScreenshot       String?
  betmgmCheckPassed     Boolean?
  betmgmLogin           String?
  betmgmPassword        String?
  betmgmRegScreenshot   String?
  betmgmLoginScreenshot String?

  livesAtDifferentAddress  Boolean  @default(false)
  currentAddress           String?
  differentAddressDuration String?
  differentAddressProof    String?

  // Step 2: Background
  ssnDocument        String?
  secondAddress      String?
  hasCriminalRecord  Boolean?
  criminalRecordNotes String?
  bankingHistory     String?
  paypalHistory      String?
  sportsbookHistory  String?

  // Step 3: Platforms
  platformData Json?

  // Step 4: Contract
  contractDocument String?

  // Risk flags
  paypalPreviouslyUsed Boolean @default(false)
  addressMismatch      Boolean @default(false)
  debankedHistory      Boolean @default(false)
  debankedBank         String?
  undisclosedInfo      Boolean @default(false)

  // Relations
  closerId       String
  closer         User    @relation("DraftCloser", fields: [closerId], references: [id])
  resultClientId String? @unique
  resultClient   Client? @relation("DraftResult", fields: [resultClientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Bonus Pool ─────────────────────────────────────────

model BonusPool {
  id       String          @id @default(cuid())
  clientId String          @unique
  client   Client          @relation(fields: [clientId], references: [id])

  closerId       String
  closer         User   @relation("BonusPoolCloser", fields: [closerId], references: [id])
  closerStarLevel Int

  totalAmount    Int @default(400)
  directAmount   Int @default(200)
  starPoolAmount Int @default(200)

  distributedSlices Int @default(0)
  recycledSlices    Int @default(0)

  status        BonusPoolStatus @default(PENDING)
  distributedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocations BonusAllocation[]
}

// ─── Bonus Allocation ───────────────────────────────────

model BonusAllocation {
  id     String         @id @default(cuid())
  poolId String
  pool   BonusPool      @relation(fields: [poolId], references: [id])

  agentId       String
  agent         User           @relation("AllocationAgent", fields: [agentId], references: [id])
  agentStarLevel Int

  type    AllocationType
  slices  Int
  amount  Int

  status  AllocationStatus @default(PENDING)
  paidAt  DateTime?
  paidById String?
  paidBy   User?   @relation("AllocationPayer", fields: [paidById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Promotion Log ──────────────────────────────────────

model PromotionLog {
  id      String @id @default(cuid())
  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  previousStarLevel    Int
  newStarLevel         Int
  previousLeadershipTier LeadershipTier @default(NONE)
  newLeadershipTier      LeadershipTier @default(NONE)
  promotionBonus       Int?
  approvedClientCount  Int
  metadata             Json?

  createdAt DateTime @default(now())
}

// ─── Quarterly Settlement ───────────────────────────────

model QuarterlySettlement {
  id       String @id @default(cuid())
  leaderId String
  leader   User   @relation(fields: [leaderId], references: [id])

  leaderTier        LeadershipTier
  year              Int
  quarter           Int
  teamRevenue       Decimal @db.Decimal(12, 2)
  commissionPercent Int
  commissionAmount  Decimal @db.Decimal(12, 2)
  teamAgentIds      String[]
  metadata          Json?

  status QuarterlySettlementStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leaderId, year, quarter])
}

// ─── Event Log ───────────────────────────────────────────

model EventLog {
  id          String    @id @default(cuid())
  eventType   EventType
  description String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  metadata    Json?
  createdAt   DateTime  @default(now())
}
