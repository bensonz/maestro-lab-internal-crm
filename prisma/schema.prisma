generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  AGENT
  BACKOFFICE
  ADMIN
  FINANCE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  LOGIN
  LOGOUT
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String
  role         UserRole @default(AGENT)
  phone        String?
  avatar       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Hierarchy
  supervisorId String?
  supervisor   User?  @relation("UserHierarchy", fields: [supervisorId], references: [id])
  subordinates User[] @relation("UserHierarchy")

  // Agent profile
  tier          String @default("rookie")
  starLevel     Int    @default(0)
  gender        String?
  dateOfBirth   DateTime?
  idNumber      String?
  idExpiry      DateTime?
  idDocument      String?
  addressDocument String?
  ssn             String?
  citizenship   String?
  personalEmail String?
  personalPhone String?
  companyPhone  String?
  carrier       String?
  zelle         String?
  address       String?
  loginAccount  String?

  // Relations
  eventLogs              EventLog[]
  reviewedApplications   AgentApplication[] @relation("ApplicationReviewer")
  resultOfApplications   AgentApplication[] @relation("ApplicationResult")
}

// ─── Agent Application ───────────────────────────────────

model AgentApplication {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)

  // Applicant info
  firstName   String
  lastName    String
  email       String
  phone       String
  password    String // hashed

  // Personal
  gender      String?
  dateOfBirth DateTime?
  citizenship String?

  // Address
  address String?
  city    String?
  state   String?
  zipCode String?
  country String?

  // ID document
  idDocument      String?
  addressDocument String?
  idNumber        String?
  idExpiry        DateTime?

  // Payment
  zelle String?

  // Referral
  referredByName String?

  // Review
  reviewedById String?
  reviewedBy   User?    @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?

  // Links to created user on approval
  resultUserId String?
  resultUser   User?   @relation("ApplicationResult", fields: [resultUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Event Log ───────────────────────────────────────────

model EventLog {
  id          String    @id @default(cuid())
  eventType   EventType
  description String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  metadata    Json?
  createdAt   DateTime  @default(now())
}
